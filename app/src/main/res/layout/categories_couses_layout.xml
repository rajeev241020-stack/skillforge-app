<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="180dp"
    android:layout_marginTop="10dp"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="5dp"
    android:background="@drawable/edit_drawable_shape"
    android:orientation="vertical"
    android:layout_height="180dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:background="@drawable/shape_courses"
            android:id="@+id/layout_color"
            android:orientation="vertical"
            android:gravity="center">
            <View
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:id="@+id/view_color"
                android:background="@drawable/button_shape_courses"/>
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android Development"
            android:layout_marginTop="10dp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:id="@+id/courses_name"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 courses"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.02"
            android:textSize="14sp"
            android:textColor="#A1A3AE"
            android:id="@+id/courses_number"/>

    </LinearLayout>



</LinearLayout>