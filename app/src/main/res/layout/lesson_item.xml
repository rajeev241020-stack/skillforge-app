<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:layout_marginTop="8dp"
    android:background="@drawable/edit_drawable_shape"
    android:gravity="center_vertical">

    <LinearLayout
        android:id="@+id/layout_icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/button_shape_courses"
        android:gravity="center">

        <ImageView
            android:id="@+id/iv_play_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_autoplay_24"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_lesson_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome &amp; Setup"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/tv_lesson_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8 min"
            android:textSize="12sp"
            android:textColor="#A1A3AE"
            android:layout_marginTop="2dp"/>

    </LinearLayout>
    <TextView
        android:id="@+id/tv_free_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FREE"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#2dd4bf"
        android:background="@drawable/free_badge_bg"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:visibility="gone"/>

</LinearLayout>